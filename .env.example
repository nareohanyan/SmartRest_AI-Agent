SMARTREST_APP_NAME="SmartRest AI Agent"
SMARTREST_APP_ENV=development
SMARTREST_APP_HOST=0.0.0.0
SMARTREST_APP_PORT=8000
SMARTREST_LOG_LEVEL=INFO
SMARTREST_AUTH_SECRET_KEY=
SMARTREST_AUTH_TOKEN_MAX_AGE_SECONDS=300
SMARTREST_AUTH_TOKEN_MAX_FUTURE_SKEW_SECONDS=30

OPENAI_API_KEY=
SMARTREST_DATABASE_URL=postgresql+psycopg://smartrest:smartrest@smartrest_db:5432/smartrest
SMARTREST_CHAT_ANALYTICS_DATABASE_URL=postgresql+psycopg://smartrest:smartrest@smartrest_db:5432/chat_analytics_db
TOON_LAHMAJO_DB=mysql+pymysql://root:pass@database:3306/toon_lahmajo
SMARTREST_SCOPE_BACKEND_MODE=db_with_fallback
SMARTREST_REPORT_BACKEND_MODE=db_with_fallback
SMARTREST_SYNC_BATCH_SIZE_TABLES=1000
