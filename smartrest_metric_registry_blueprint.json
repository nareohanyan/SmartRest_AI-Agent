  "formula_contract": {
    "principle": "Formula strings are human-readable documentation. Runtime execution must use validated machine-safe formula structures.",
    "documentation_field": "formula",
    "executable_field": "formula_ast",
    "allowed_formula_ast_kinds": [
      "metric_ref",
      "const",
      "ratio",
      "sum",
      "difference",
      "multiply"
    ],
    "validation_rules": [
      "All metric refs in formula_ast must exist in metric registry.",
      "Derived metric dependencies must match formula_ast refs.",
      "Division by zero must return null and emit warning.",
      "Planner may reference only registered metric IDs."
    ]
  },
  "metric_operational_contract": {
    "principle": "Every canonical metric needs operational trust metadata beyond semantic definition.",
    "required_fields": [
      "source_entity",
      "owner",
      "refresh_sla",
      "freshness_check",
      "quality_checks",
      "null_handling",
      "zero_handling",
      "late_arrival_policy"
    ],
    "status": "required_before_production_execution"
  },
  "planning_examples": [
    {
      "user_request": "Which source dropped the most last month compared to the previous month?",
      "planner_output_shape": {
        "metric": "net_sales",
        "dimensions": [
          "source"
        ],
        "time_range": "last_month",
        "comparison_window": "previous_month",
        "operations": [
          "breakdown",
          "compare",
          "rank"
        ]
      },
      "important_note": "The planner dynamically composes approved operations. It does not invent a new metric."
    },
    {
      "user_request": "Show average check trend by day for this week.",
      "planner_output_shape": {
        "metric": "average_check",
        "dimensions": [
          "day"
        ],
        "time_range": "current_week",
        "operations": [
          "timeseries",
          "trend"
        ]
      },
      "important_note": "Trend analysis is dynamic, but the metric definition remains stable."
    }
  ],
