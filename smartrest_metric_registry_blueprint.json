{
  "document": {
    "title": "SmartRest Production Metric Registry and Dynamic Planning Blueprint",
    "version": "1.1.0",
    "created_at": "2026-03-24",
    "purpose": "A structured blueprint explaining how to model a production analytics agent using a small canonical metric registry, stable dimensions, bounded analytical operations, and dynamic planning over those stable business semantics."
  },
  "core_principle": {
    "summary": "Do not define every possible user question. Define a small, governed system of business metrics, dimensions, and analytical operations. Let the planner dynamically compose them.",
    "wrong_model": {
      "name": "Dynamic metric invention",
      "description": "The LLM invents new business metrics on the fly from user phrasing.",
      "why_it_fails": [
        "Different runs may produce different meanings for the same business term.",
        "Permission enforcement becomes unclear and fragile.",
        "Testing and debugging become extremely difficult.",
        "Numbers may drift away from dashboards and official definitions.",
        "Business trust drops when definitions are unstable."
      ]
    },
    "right_model": {
      "name": "Dynamic planning over stable semantics",
      "description": "Metrics, dimensions, and formulas are predefined and governed. The planner dynamically chooses which approved semantics and operations to compose for a given request.",
      "benefits": [
        "Stable business definitions",
        "Deterministic calculations",
        "Clear permission boundaries",
        "Better observability and testing",
        "Scalable request coverage without metric explosion"
      ]
    }
  },
  "three_layers": {
    "base_metrics": {
      "definition": "Canonical business facts that come directly from trusted data sources and have stable meaning.",
      "examples": [
        "gross_sales",
        "net_sales",
        "order_count",
        "refund_amount",
        "discount_amount"
      ]
    },
    "derived_metrics": {
      "definition": "Metrics defined as stable formulas over base metrics.",
      "examples": [
        "average_check = net_sales / completed_order_count",
        "refund_rate = refund_amount / net_sales",
        "discount_share = discount_amount / gross_sales"
      ]
    },
    "dynamic_analyses": {
      "definition": "Planner-driven combinations of existing metrics with dimensions, time windows, and operations.",
      "examples": [
        "sales by source last month",
        "average check trend by day",
        "top 5 branches by order count",
        "compare current month vs previous month by source"
      ]
    }
  },
  "design_rules": [
    "Keep core business metric definitions stable and versioned.",
    "Separate metric definitions from dynamic analytical operations.",
    "Treat dimensions as a separate governed registry.",
    "Map user language to canonical metrics and dimensions through aliases.",
    "Perform calculations in tools, not inside free-form model reasoning.",
    "Use dynamic planning to compose approved operations, not invent semantics.",
    "Attach permissions to scope, metrics, dimensions, and operations.",
    "Make every analytical step observable and testable."
  ],
  "canonical_decisions": {
    "average_check_definition": {
      "canonical_formula": "net_sales / completed_order_count",
      "definition_version": "v2",
      "business_meaning": "Average realized sales per completed order.",
      "inclusion_rules": [
        "Include only completed orders in denominator.",
        "Exclude canceled orders from denominator.",
        "Refund handling stays in net_sales numerator.",
        "If completed_order_count is zero, return null and emit division-by-zero warning."
      ],
      "transition_note": "Current runtime may still use sales_total / order_count. Migrate with explicit versioning and dashboard parity checks."
    }
  },
  "operation_vocabulary": {
    "principle": "Planner uses semantic operations; runtime uses explicit executable tool operations. Mapping is mandatory and versioned.",
    "semantic_planning_operations": [
      "total",
      "breakdown",
      "timeseries",
      "compare",
      "rank",
      "share",
      "trend"
    ],
    "runtime_execution_operations": [
      "resolve_scope",
      "run_report",
      "compute_scalar_metrics",
      "fetch_total_metric",
      "fetch_breakdown",
      "fetch_timeseries",
      "attach_breakdown_share",
      "top_k",
      "bottom_k",
      "moving_average",
      "trend_slope"
    ],
    "semantic_to_runtime_mapping": [
      {
        "semantic_op": "total",
        "runtime_ops": [
          "fetch_total_metric"
        ]
      },
      {
        "semantic_op": "breakdown",
        "runtime_ops": [
          "fetch_breakdown"
        ]
      },
      {
        "semantic_op": "timeseries",
        "runtime_ops": [
          "fetch_timeseries"
        ]
      },
      {
        "semantic_op": "compare",
        "runtime_ops": [
          "fetch_total_metric",
          "compute_scalar_metrics"
        ]
      },
      {
        "semantic_op": "rank",
        "runtime_ops": [
          "fetch_breakdown",
          "top_k",
          "bottom_k"
        ]
      },
      {
        "semantic_op": "share",
        "runtime_ops": [
          "attach_breakdown_share"
        ]
      },
      {
        "semantic_op": "trend",
        "runtime_ops": [
          "fetch_timeseries",
          "moving_average",
          "trend_slope"
        ]
      }
    ],
    "trust_operations": [
      "check_freshness",
      "check_data_quality",
      "emit_warnings"
    ]
  },
