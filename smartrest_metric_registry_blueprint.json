  "implementation_path": {
    "phase_1": "Introduce canonical metric and dimension registries as versioned metadata.",
    "phase_2": "Finalize metric consistency decisions (including average_check denominator and version migration notes).",
    "phase_3": "Adopt two-layer operation vocabulary with explicit semantic-to-runtime mapping.",
    "phase_4": "Map user language to canonical metric IDs, dimension IDs, and semantic operations.",
    "phase_5": "Enforce planner outputs to approved metrics, dimensions, and mapped runtime operations only.",
    "phase_6": "Use formula_ast for deterministic derived-metric execution; keep formula strings as documentation.",
    "phase_7": "Add metric operational trust metadata: lineage, freshness, quality, and null/zero policies.",
    "phase_8": "Enforce branch-scope and export permissions in runtime contracts.",
    "phase_9": "Expose evidence payloads and execution traces for grounding and debugging."
  },
  "anti_patterns": [
    "Inventing business metrics dynamically from user phrasing",
    "Letting the model perform important business calculations in hidden reasoning",
    "Creating a separate hardcoded tool for every question shape",
    "Coupling permissions only to report IDs once dynamic routes exist",
    "Treating dimensions as ungoverned free text",
    "Using formula strings as executable truth without validated formula_ast",
    "Keeping semantic and runtime operation vocabularies unaligned"
  ],
  "one_sentence_summary": "Do not create a huge list of question-specific metrics. Create a small, governed metric registry and let dynamic planning compose those metrics with approved dimensions and operations."
}
